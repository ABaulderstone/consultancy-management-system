{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["date", "revenue", "cost", "profit", "projected"],
    "additionalProperties": false,
    "properties": {
      "date": { "type": "string", "format": "date" },
      "revenue": { "type": "number" },
      "cost": { "type": "number" },
      "profit": { "type": "number" },
      "projected": { "type": "boolean" }
    }
  }
}
