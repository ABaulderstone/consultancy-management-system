{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "start_date"],
  "properties": {
    "id": { "type": "integer" },
    "start_date": { "type": "string" },
    "end_date": { "type": ["string", "null"] },
    "job": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "client": { "type": "string" },
        "day_rate": { "type": "number" }
      }
    }
  }
}
